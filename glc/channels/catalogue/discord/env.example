# Discord channel adapter — environment template
#
# Copy the values below into a file named `.env` at the REPOSITORY ROOT
# (same folder as pyproject.toml). The adapter's scripts and live tests
# load that root .env automatically via python-dotenv.
#
#     cp glc/channels/catalogue/discord/env.example .env
#     # then edit .env and fill in real values
#
# NOTE: the real `.env` is git-ignored on purpose — never commit it.
# See help_docs/discord_channel_bot.md for a full walkthrough with screenshots.

# --- Required -------------------------------------------------------------

# Bot token: Discord Developer Portal -> your app -> Bot -> Reset Token -> Copy.
# Also enable, on the same Bot page under "Privileged Gateway Intents":
#   - Message Content Intent  (required to read message text)
#   - Server Members Intent   (required for get_user() mention resolution)
DISCORD_BOT_TOKEN=your_bot_token_here

# --- Required for the live REST/send tests --------------------------------

# A channel the bot can post to. In the Discord app: enable Developer Mode
# (User Settings -> Advanced), then right-click the channel -> Copy Channel ID.
DISCORD_TEST_CHANNEL_ID=your_channel_id_here

# --- Optional (only used by test_get_user_resolves_handle) ----------------

# Any valid user ID, used to verify get_user() resolution.
# Right-click a user in the Discord app -> Copy User ID.
DISCORD_TEST_USER_ID=your_user_id_here
